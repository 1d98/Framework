#!/usr/bin/env php
<?php

declare(strict_types=1);

use Framework\Config\Config;
use Framework\Config\ConfigInterface;
use Framework\Console\Application;
use Framework\Console\Command\AppSecretCommand;
use Framework\Console\Command\ConfigShowCommand;
use Framework\Console\Command\ListCommand;
use Framework\Console\Command\Make\MakeCommandCommand;
use Framework\Console\Command\Make\MakeControllerCommand;
use Framework\Console\Command\Make\MakeDtoCommand;
use Framework\Console\Command\Make\MakeExceptionCommand;
use Framework\Console\Command\Make\MakeMiddlewareCommand;
use Framework\Console\Command\Make\MakeRuleCommand;
use Framework\Console\Command\RoutesListCommand;
use Framework\Container\Container;
use Framework\Http\Router\Router;

require_once __DIR__ . '/../vendor/autoload.php';

/**
 * Resolve the target directory for a make:* command.
 *
 * When run from the framework's own repo (development), use the repo's
 * `src/...` tree. When installed via Composer, the consumer's project
 * root is the CWD — write there under conventional paths.
 *
 * @param string $frameworkSubPath e.g. 'src/Http/Controller'
 */
function makeTargetDir(string $frameworkSubPath): string
{
    $frameworkRoot = \dirname(__DIR__);
    $isFrameworkRepo = is_file($frameworkRoot . '/composer.json')
        && is_dir($frameworkRoot . '/.git');
    if ($isFrameworkRepo) {
        return $frameworkRoot . '/' . $frameworkSubPath;
    }
    return getcwd() . '/' . $frameworkSubPath;
}

/**
 * Resolve the explicit namespace override for a make:* command.
 *
 * Returns the FQCN prefix when running from the framework's own repo
 * (so generated files land in the `Framework\…` namespaces, regardless
 * of what the framework's own `composer.json` declares for `psr-4`).
 * Returns `null` in consumer mode so the per-command `NamespaceResolver`
 * picks the namespace from the consumer's own `composer.json`.
 *
 * This guards against a fork / rename of the framework that changes
 * the `psr-4` prefix in `composer.json` — without the override, the
 * resolver would derive a `Framework\…` namespace from the framework
 * `composer.json` for dev-mode writes into the repo, which would
 * still work only by coincidence.
 *
 * @param string $subNamespace e.g. 'Console\Command' or 'Http\Controller'
 */
function makeNamespaceOverride(string $subNamespace): ?string
{
    $frameworkRoot = \dirname(__DIR__);
    $isFrameworkRepo = is_file($frameworkRoot . '/composer.json')
        && is_dir($frameworkRoot . '/.git');
    if ($isFrameworkRepo) {
        return 'Framework\\' . $subNamespace;
    }
    return null;
}

/**
 * Resolve the initial debug flag from the `APP_DEBUG` env var.
 * `Application::isDebug()` may still be overridden at runtime by
 * `--debug` / `--no-debug` flags.
 */
function envDebug(): bool
{
    $value = getenv('APP_DEBUG');
    if ($value === false || $value === '') {
        return false;
    }
    return in_array(strtolower($value), ['1', 'true', 'yes', 'on'], true);
}

$container = new Container();
$container->set(ConfigInterface::class, static fn(): ConfigInterface
    => Config::fromArray([
        'app' => [
            'env' => getenv('APP_ENV') ?: 'dev',
            'version' => \Framework\Framework::VERSION,
        ],
    ]));
$container->set(Router::class, static fn(): Router => new Router());

$app = new Application($container, 'Framework Console', \Framework\Framework::VERSION, debug: envDebug());
$app
    ->add(new ListCommand($container, $app))
    ->add(new ConfigShowCommand($container, $container->get(ConfigInterface::class)))
    ->add(new RoutesListCommand($container, $container->get(Router::class)))
    ->add(new AppSecretCommand($container))
    ->add(new MakeCommandCommand(
        $container,
        makeTargetDir('src/Console/Command'),
        namespaceOverride: makeNamespaceOverride('Console\Command'),
    ))
    ->add(new MakeControllerCommand(
        $container,
        makeTargetDir('src/Http/Controller'),
        namespaceOverride: makeNamespaceOverride('Http\Controller'),
    ))
    ->add(new MakeExceptionCommand(
        $container,
        makeTargetDir('src/Http/Exception'),
        namespaceOverride: makeNamespaceOverride('Http\Exception'),
    ))
    ->add(new MakeMiddlewareCommand(
        $container,
        makeTargetDir('src/Http/Middleware'),
        namespaceOverride: makeNamespaceOverride('Http\Middleware'),
    ))
    ->add(new MakeRuleCommand(
        $container,
        makeTargetDir('src/Validation/Rule'),
        namespaceOverride: makeNamespaceOverride('Validation\Rule'),
    ))
    ->add(new MakeDtoCommand(
        $container,
        makeTargetDir('src/Validation/Dto'),
        namespaceOverride: makeNamespaceOverride('Validation\Dto'),
    ));

exit($app->run($argv));
