#!/usr/bin/env php
<?php

declare(strict_types=1);

use Framework\Config\Config;
use Framework\Config\ConfigInterface;
use Framework\Console\Application;
use Framework\Console\Command\AppSecretCommand;
use Framework\Console\Command\ConfigShowCommand;
use Framework\Console\Command\ListCommand;
use Framework\Console\Command\Make\MakeCommandCommand;
use Framework\Console\Command\Make\MakeControllerCommand;
use Framework\Console\Command\Make\MakeDtoCommand;
use Framework\Console\Command\Make\MakeExceptionCommand;
use Framework\Console\Command\Make\MakeMiddlewareCommand;
use Framework\Console\Command\Make\MakeRuleCommand;
use Framework\Console\Command\RoutesListCommand;
use Framework\Container\Container;
use Framework\Http\Router\Router;

require_once __DIR__ . '/../vendor/autoload.php';

/**
 * Resolve the target directory for a make:* command.
 *
 * When run from the framework's own repo (development), use the repo's
 * `src/...` tree. When installed via Composer, the consumer's project
 * root is the CWD — write there under conventional paths.
 *
 * @param string $frameworkSubPath e.g. 'src/Http/Controller'
 */
function makeTargetDir(string $frameworkSubPath): string
{
    $frameworkRoot = \dirname(__DIR__);
    $isFrameworkRepo = is_file($frameworkRoot . '/composer.json')
        && is_dir($frameworkRoot . '/.git');
    if ($isFrameworkRepo) {
        return $frameworkRoot . '/' . $frameworkSubPath;
    }
    return getcwd() . '/' . $frameworkSubPath;
}

$container = new Container();
$container->set(ConfigInterface::class, static fn(): ConfigInterface
    => Config::fromArray([
        'app' => [
            'env' => getenv('APP_ENV') ?: 'dev',
            'version' => \Framework\Framework::VERSION,
        ],
    ]));
$container->set(Router::class, static fn(): Router => new Router());

$app = new Application($container, 'Framework Console', \Framework\Framework::VERSION);
$app
    ->add(new ListCommand($container, $app))
    ->add(new ConfigShowCommand($container, $container->get(ConfigInterface::class)))
    ->add(new RoutesListCommand($container, $container->get(Router::class)))
    ->add(new AppSecretCommand($container))
    ->add(new MakeCommandCommand($container, makeTargetDir('src/Console/Command')))
    ->add(new MakeControllerCommand($container, makeTargetDir('src/Http/Controller')))
    ->add(new MakeExceptionCommand($container, makeTargetDir('src/Http/Exception')))
    ->add(new MakeMiddlewareCommand($container, makeTargetDir('src/Http/Middleware')))
    ->add(new MakeRuleCommand($container, makeTargetDir('src/Validation/Rule')))
    ->add(new MakeDtoCommand($container, makeTargetDir('src/Validation/Dto')));

exit($app->run($argv));
