# Example environment variables for the framework.
# Copy this file to `.env` (in project root) and adjust for your local setup.
# Real environment variables always win over .env values (override=false default).
# .env is gitignored; .env.example is the tracked template.

# Application environment: 'dev' (default) or 'prod'.
# In 'prod', HttpsRedirectMiddleware + stricter behavior activates.
APP_ENV=dev

# Debug mode: 1 = expose exception details and stack traces; 0 = production-safe.
APP_DEBUG=1

# HMAC secret for SignedCookieJar (CSRF tokens, signed cookies).
# In production, APP_SECRET MUST be at least 32 random characters. The default below will be rejected at boot.
# Generate with: `php bin/framework app:secret` or `openssl rand -hex 32`.
# Provide it via the real env var APP_SECRET in your secrets manager — never commit a real secret.
APP_SECRET=dev-only-secret-change-in-prod

# Directory for temporary uploaded files (used by MultipartBodyParser).
# Defaults to project-local var/tmp/ if unset. Override for sandboxed environments.
APP_UPLOAD_TMP_DIR=

# Comma-separated list of trusted Host header values (and `*.example.com`
# wildcards) the HTTPS redirector may reflect into `Location:`. Required
# in production. Falls back to Request::TRUSTED_HOSTS_DEFAULT (localhost,
# 127.0.0.1, *.localhost) when unset, which is only safe for dev.
APP_TRUSTED_HOSTS=

# Comma-separated list of trusted reverse-proxy CIDRs / IPs that may set
# `X-Forwarded-Proto` and `X-Forwarded-For`. Empty (the default) keeps the
# strict mode: those headers are NEVER trusted, and Request::isSecure() /
# Request::ip() return the immediate-connection values from REMOTE_ADDR.
# Set this in any deployment behind a load balancer or reverse proxy so
# the framework can honor the forwarded headers from the edge.
# Example: APP_TRUSTED_PROXIES=10.0.0.0/8,127.0.0.1/32,::1/128
APP_TRUSTED_PROXIES=
